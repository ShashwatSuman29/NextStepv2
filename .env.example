# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (pooler URL for production)
DATABASE_URL=postgres://postgres.[ref]:[pw]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Error tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxx.ingest.sentry.io/xxxx
SENTRY_ORG=your-org
SENTRY_PROJECT=nextstep
SENTRY_AUTH_TOKEN=sntrys_xxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
